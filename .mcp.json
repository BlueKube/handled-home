{
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=gwbwnetatpgnqgarkvht"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "chrome-devtools": {
      "command": "bash",
      "args": ["scripts/start-chrome-devtools-mcp.sh"]
    }
  }
}
